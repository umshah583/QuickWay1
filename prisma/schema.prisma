generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Account {
  id                String  @id
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  User              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model AdminSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String?
  updatedAt DateTime @default(now())
}

model Area {
  id                 String               @id
  name               String               @unique
  description        String?
  minLatitude        Float
  maxLatitude        Float
  minLongitude       Float
  maxLongitude       Float
  polygonJson        String?
  active             Boolean              @default(true)
  sortOrder          Int                  @default(0)
  priceMultiplier    Float                @default(1.0)
  createdAt          DateTime             @default(now())
  updatedAt          DateTime
  centerLatitude     Float?
  centerLongitude    Float?
  radiusMeters       Int?
  Booking            Booking[]
  PackageZonePricing PackageZonePricing[]
  ServiceAreaPrice   ServiceAreaPrice[]
  SpotOrder          SpotOrder[]

  @@index([active, sortOrder])
}

model Booking {
  id                                            String            @id @default(cuid())
  userId                                        String
  serviceId                                     String
  startAt                                       DateTime
  endAt                                         DateTime
  status                                        BookingStatus     @default(PENDING)
  driverId                                      String?
  partnerId                                     String?
  taskStatus                                    TaskStatus        @default(ASSIGNED)
  cashCollected                                 Boolean           @default(false)
  cashSettled                                   Boolean           @default(false)
  cashAmountCents                               Int?              @default(0)
  loyaltyCreditAppliedCents                     Int               @default(0)
  loyaltyCreditConsumed                         Boolean           @default(false)
  loyaltyPointsApplied                          Int               @default(0)
  couponId                                      String?
  couponCode                                    String?
  couponDiscountCents                           Int               @default(0)
  driverNotes                                   String?
  beforePhotoUrl                                String?
  afterPhotoUrl                                 String?
  freeWashRewardCouponId                        String?
  freeWashRewardCouponCode                      String?
  freeWashRewardIssuedAt                        DateTime?
  locationLabel                                 String?
  locationCoordinates                           String?
  customerLatitude                              Float?
  customerLongitude                             Float?
  driverLatitude                                Float?
  driverLongitude                               Float?
  driverLocationUpdatedAt                       DateTime?
  vehicleMake                                   String?
  vehicleModel                                  String?
  vehicleColor                                  String?
  vehicleType                                   String?
  vehiclePlate                                  String?
  vehicleServiceDetails                         String?
  vehicleCount                                  Int               @default(1)
  partnerCommissionPercentage                   Float?
  servicePriceCents                             Int?
  serviceDiscountPercentage                     Float?
  taxPercentage                                 Float?
  stripeFeePercentage                           Float?
  extraFeeCents                                 Int?
  createdAt                                     DateTime          @default(now())
  updatedAt                                     DateTime          @default(now())
  taskStartedAt                                 DateTime?
  taskCompletedAt                               DateTime?
  areaId                                        String?
  areaName                                      String?
  invoiceNumber                                 String?           @unique
  orderNumber                                   String?           @unique
  Area                                          Area?             @relation(fields: [areaId], references: [id])
  Coupon_Booking_couponIdToCoupon               Coupon?           @relation("Booking_couponIdToCoupon", fields: [couponId], references: [id])
  User_Booking_driverIdToUser                   User?             @relation("Booking_driverIdToUser", fields: [driverId], references: [id])
  Coupon_Booking_freeWashRewardCouponIdToCoupon Coupon?           @relation("Booking_freeWashRewardCouponIdToCoupon", fields: [freeWashRewardCouponId], references: [id])
  Partner                                       Partner?          @relation(fields: [partnerId], references: [id])
  Service                                       Service           @relation(fields: [serviceId], references: [id])
  User_Booking_userIdToUser                     User              @relation("Booking_userIdToUser", fields: [userId], references: [id], onDelete: Cascade)
  ChatConversation                              ChatConversation?
  CouponRedemption                              CouponRedemption?
  Feedback                                      Feedback[]
  Payment                                       Payment?

  @@index([areaId])
  @@index([couponId])
  @@index([serviceId, startAt])
  @@index([userId, startAt])
}

model SpotOrder {
  id                        String               @id @default(cuid())
  driverId                  String
  zoneId                    String
  serviceId                 String
  locationLabel             String
  locationCoordinates       String?
  vehiclePlate              String?
  vehicleCount              Int                  @default(1)
  vehicleServiceDetails     String?
  status                    SpotOrderStatus      @default(PENDING)
  priceCents                Int
  driverNotes               String?
  createdAt                 DateTime             @default(now())
  updatedAt                 DateTime             @default(now())
  acceptedAt                DateTime?
  completedAt               DateTime?
  
  // Relations
  Area                      Area                 @relation(fields: [zoneId], references: [id])
  Service                   Service              @relation(fields: [serviceId], references: [id])
  User_SpotOrder_driverIdToUser User               @relation("SpotOrder_driverIdToUser", fields: [driverId], references: [id])

  @@index([driverId, status])
  @@index([zoneId, status])
  @@index([serviceId])
}

model BusinessHours {
  id            String   @id @default(cuid())
  startTime     String
  endTime       String
  durationHours Int
  isActive      Boolean  @default(true)
  setById       String
  setAt         DateTime @default(now())
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @default(now()) @updatedAt
  User          User     @relation(fields: [setById], references: [id])

  @@index([isActive])
  @@index([setById])
}

model ChatConversation {
  id                                     String                 @id
  bookingId                              String                 @unique
  customerId                             String
  driverId                               String
  status                                 ChatConversationStatus @default(ACTIVE)
  createdAt                              DateTime               @default(now())
  updatedAt                              DateTime
  Booking                                Booking                @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  User_ChatConversation_customerIdToUser User                   @relation("ChatConversation_customerIdToUser", fields: [customerId], references: [id])
  User_ChatConversation_driverIdToUser   User                   @relation("ChatConversation_driverIdToUser", fields: [driverId], references: [id])
  ChatMessage                            ChatMessage[]

  @@index([bookingId])
  @@index([customerId, driverId])
}

model ChatMessage {
  id               String           @id
  conversationId   String
  senderId         String
  senderType       ChatSenderType
  message          String
  messageType      ChatMessageType  @default(TEXT)
  readAt           DateTime?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime
  ChatConversation ChatConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  User             User             @relation(fields: [senderId], references: [id])

  @@index([conversationId, createdAt])
  @@index([senderId])
}

model Coupon {
  id                                             String             @id
  code                                           String             @unique
  name                                           String
  description                                    String?
  discountType                                   CouponDiscountType
  discountValue                                  Int
  maxRedemptions                                 Int?
  maxRedemptionsPerUser                          Int?
  minBookingAmountCents                          Int?
  validFrom                                      DateTime?
  validUntil                                     DateTime?
  active                                         Boolean            @default(true)
  appliesToAllServices                           Boolean            @default(true)
  applicableServiceIds                           String[]
  createdByAdminId                               String?
  createdAt                                      DateTime           @default(now())
  updatedAt                                      DateTime
  Booking_Booking_couponIdToCoupon               Booking[]          @relation("Booking_couponIdToCoupon")
  Booking_Booking_freeWashRewardCouponIdToCoupon Booking[]          @relation("Booking_freeWashRewardCouponIdToCoupon")
  User                                           User?              @relation(fields: [createdByAdminId], references: [id])
  CouponRedemption                               CouponRedemption[]
}

model CouponRedemption {
  id          String   @id
  couponId    String
  bookingId   String   @unique
  userId      String
  amountCents Int
  createdAt   DateTime @default(now())
  Booking     Booking  @relation(fields: [bookingId], references: [id])
  Coupon      Coupon   @relation(fields: [couponId], references: [id])
  User        User     @relation(fields: [userId], references: [id])

  @@index([couponId])
  @@index([userId])
}

model DriverDay {
  id                 String            @id
  driverId           String
  date               DateTime
  status             BusinessDayStatus @default(OPEN)
  startedAt          DateTime          @default(now())
  endedAt            DateTime?
  tasksCompleted     Int               @default(0)
  tasksInProgress    Int               @default(0)
  cashCollectedCents Int               @default(0)
  cashSettledCents   Int               @default(0)
  startNotes         String?
  endNotes           String?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime
  User               User              @relation(fields: [driverId], references: [id])
  DriverBreak        DriverBreak[]
  DriverBreakApprovalRequest DriverBreakApprovalRequest[]

  @@unique([driverId, date])
  @@index([date, status])
  @@index([driverId, status])
}

model DriverBreak {
  id            String    @id
  driverId      String
  driverDayId   String
  reason        String    // LUNCH, REST, PERSONAL, EMERGENCY, OTHER
  reasonDisplay String    // "Lunch Break", "Rest Break", etc.
  notes         String?
  startedAt     DateTime  @default(now())
  endedAt       DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @default(now())
  User          User      @relation("DriverBreak_driverIdToUser", fields: [driverId], references: [id])
  DriverDay     DriverDay @relation(fields: [driverDayId], references: [id])

  @@index([driverId, startedAt])
  @@index([driverDayId])
  @@index([endedAt])
}

model DriverBreakApprovalRequest {
  id                   String   @id
  driverId             String
  driverDayId          String
  reason               String   // LUNCH, REST, PERSONAL, EMERGENCY, OTHER
  reasonDisplay        String   // "Lunch Break", "Rest Break", etc.
  notes                String?
  requestedDuration    Int?     // Requested break duration in minutes
  totalBreakTimeToday  Int      // Total break time already taken today
  status               String   @default("PENDING") // PENDING, APPROVED, REJECTED
  approvedBy           String?  // Admin user ID who approved/rejected
  approvedAt           DateTime?
  rejectionReason      String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @default(now())
  User                 User     @relation(fields: [driverId], references: [id])
  DriverDay            DriverDay @relation(fields: [driverDayId], references: [id])

  @@index([driverId, status])
  @@index([status, createdAt])
  @@index([driverDayId])
}

model Feedback {
  id        String    @id
  userId    String
  bookingId String
  driverId  String?
  serviceId String
  message   String
  rating    Int?
  read      Boolean   @default(false)
  readAt    DateTime?
  createdAt DateTime  @default(now())
  Booking   Booking   @relation(fields: [bookingId], references: [id])
  User      User      @relation(fields: [userId], references: [id])
}

model Module {
  id                   String                 @id
  key                  String                 @unique
  name                 String
  description          String?
  icon                 String?
  path                 String
  sortOrder            Int                    @default(0)
  active               Boolean                @default(true)
  createdAt            DateTime               @default(now())
  updatedAt            DateTime
  RoleModulePermission RoleModulePermission[]
  UserModulePermission UserModulePermission[]

  @@index([active])
  @@index([sortOrder])
}

model MonthlyPackage {
  id                  String                @id
  name                String
  description         String?
  duration            PackageDuration       @default(MONTHLY)
  washesPerMonth      Int
  priceCents          Int
  discountPercent     Int?                  @default(0)
  features            String[]
  popular             Boolean               @default(false)
  status              PackageStatus         @default(ACTIVE)
  serviceIds          String[]
  serviceTypeId       String?
  selectedAttributes  String?
  createdAt           DateTime              @default(now())
  updatedAt           DateTime
  ServiceType         ServiceType?          @relation(fields: [serviceTypeId], references: [id])
  PackageSubscription PackageSubscription[]
  PackageZonePricing  PackageZonePricing[]
  SubscriptionRequest SubscriptionRequest[]

  @@index([serviceTypeId])
  @@index([status])
}

model Notification {
  id         String               @id
  userId     String
  title      String
  message    String
  category   NotificationCategory
  entityType String?
  entityId   String?
  read       Boolean              @default(false)
  readAt     DateTime?
  createdAt  DateTime             @default(now())
  updatedAt  DateTime
  User       User                 @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([createdAt])
  @@index([userId, read])
}

model PackageSubscription {
  id                                      String                    @id
  userId                                  String
  packageId                               String
  status                                  SubscriptionStatus        @default(ACTIVE)
  startDate                               DateTime
  endDate                                 DateTime
  washesRemaining                         Int
  washesUsed                              Int                       @default(0)
  autoRenew                               Boolean                   @default(true)
  paymentId                               String?
  pricePaidCents                          Int
  lastRenewalDate                         DateTime?
  nextRenewalDate                         DateTime?
  cancelledAt                             DateTime?
  cancellationReason                      String?
  preferredWashDates                      String[]                  @default([])
  driverId                                String?
  vehicleMake                             String?
  vehicleModel                            String?
  vehicleColor                            String?
  vehicleType                             String?
  vehiclePlate                            String?
  locationLabel                           String?
  locationCoordinates                     String?
  createdAt                               DateTime                  @default(now())
  updatedAt                               DateTime                  @updatedAt
  User_PackageSubscription_driverIdToUser User?                     @relation("PackageSubscription_driverIdToUser", fields: [driverId], references: [id])
  MonthlyPackage                          MonthlyPackage            @relation(fields: [packageId], references: [id])
  User_PackageSubscription_userIdToUser   User                      @relation("PackageSubscription_userIdToUser", fields: [userId], references: [id], onDelete: Cascade)
  SubscriptionDailyDriver                 SubscriptionDailyDriver[]

  @@index([packageId])
  @@index([userId, status])
}

model PackageZonePricing {
  id             String         @id
  packageId      String
  areaId         String
  priceCents     Int
  createdAt      DateTime       @default(now())
  updatedAt      DateTime
  Area           Area           @relation(fields: [areaId], references: [id])
  MonthlyPackage MonthlyPackage @relation(fields: [packageId], references: [id], onDelete: Cascade)

  @@unique([packageId, areaId])
  @@index([areaId])
  @@index([packageId])
}

model Partner {
  id                           String                  @id @default(cuid())
  name                         String
  email                        String?                 @unique
  userId                       String?                 @unique
  logoUrl                      String?
  commissionPercentage         Float?
  createdAt                    DateTime                @default(now())
  updatedAt                    DateTime                @default(now()) @updatedAt
  Booking                      Booking[]
  User_Partner_userIdToUser    User?                   @relation("Partner_userIdToUser", fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  PartnerDriverRequest         PartnerDriverRequest[]
  PartnerPayout                PartnerPayout[]
  PartnerServiceRequest        PartnerServiceRequest[]
  User_User_partnerIdToPartner User[]                  @relation("User_partnerIdToPartner")
}

model PartnerDriverRequest {
  id                   String                     @id
  partnerId            String
  name                 String
  email                String
  passwordHash         String
  mobileNumber         String                     @default("")
  visaIssueDate        DateTime?
  visaExpiryDate       DateTime?
  documentType         PartnerDriverDocumentType  @default(LABOUR_CARD)
  labourCardFileBytes  Bytes?
  labourCardFileName   String?
  labourCardFileType   String?
  emiratesIdFrontBytes Bytes?
  emiratesIdFrontName  String?
  emiratesIdFrontType  String?
  emiratesIdBackBytes  Bytes?
  emiratesIdBackName   String?
  emiratesIdBackType   String?
  status               PartnerDriverRequestStatus @default(PENDING)
  rejectionReason      String?
  processedAt          DateTime?
  processedById        String?
  rejectionCount       Int                        @default(0)
  createdAt            DateTime                   @default(now())
  updatedAt            DateTime
  Partner              Partner                    @relation(fields: [partnerId], references: [id])
  User                 User?                      @relation(fields: [processedById], references: [id])

  @@index([partnerId, status])
}

model PartnerPayout {
  id               String   @id
  partnerId        String
  amountCents      Int
  note             String?
  periodMonth      Int
  periodYear       Int
  createdAt        DateTime @default(now())
  createdByAdminId String?
  User             User?    @relation(fields: [createdByAdminId], references: [id])
  Partner          Partner  @relation(fields: [partnerId], references: [id])

  @@index([partnerId, periodYear, periodMonth])
}

model PartnerServiceRequest {
  id              String                      @id
  partnerId       String
  name            String
  description     String?
  imageUrl        String?
  durationMin     Int
  priceCents      Int
  carType         String
  serviceTypeId   String?
  attributeValues Json?
  serviceId       String?
  status          PartnerServiceRequestStatus @default(PENDING)
  rejectionReason String?
  createdAt       DateTime                    @default(now())
  processedAt     DateTime?
  processedById   String?
  Partner         Partner                     @relation(fields: [partnerId], references: [id])
  User            User?                       @relation(fields: [processedById], references: [id])
  Service         Service?                    @relation(fields: [serviceId], references: [id])
  ServiceType     ServiceType?                @relation(fields: [serviceTypeId], references: [id])

  @@index([partnerId, status])
}

model Payment {
  id          String          @id
  bookingId   String          @unique
  provider    PaymentProvider
  status      PaymentStatus
  amountCents Int
  sessionId   String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime
  Booking     Booking         @relation(fields: [bookingId], references: [id], onDelete: Cascade)
}

model SavedPaymentMethod {
  id                    String              @id
  userId                String
  type                  SavedPaymentType
  last4                 String
  brand                 String
  expiryMonth           Int
  expiryYear            Int
  stripePaymentMethodId String              @unique
  isDefault             Boolean             @default(false)
  isActive              Boolean             @default(true)
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt
  
  User                  User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId, isActive])
  @@index([userId, isDefault])
}

model Permission {
  id             String           @id
  key            String           @unique
  name           String
  description    String?
  module         String
  action         String
  RolePermission RolePermission[]
  UserPermission UserPermission[]

  @@unique([module, action])
}

model PushSubscription {
  id        String   @id
  userId    String?
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())
  User      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Role {
  id                   String                 @id
  key                  String                 @unique
  name                 String
  description          String?
  active               Boolean                @default(true)
  createdAt            DateTime               @default(now())
  updatedAt            DateTime
  isSystemRole         Boolean                @default(false)
  RoleModulePermission RoleModulePermission[]
  RolePermission       RolePermission[]
  User                 User[]

  @@index([active])
}

model RoleModulePermission {
  id        String  @id
  roleId    String
  moduleId  String
  enabled   Boolean @default(true)
  canView   Boolean @default(true)
  canCreate Boolean @default(false)
  canEdit   Boolean @default(false)
  canDelete Boolean @default(false)
  Module    Module  @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  Role      Role    @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([roleId, moduleId])
  @@index([moduleId])
  @@index([roleId])
}

model RolePermission {
  id           String     @id
  roleId       String
  permissionId String
  Permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  Role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
}

model Service {
  id                    String                  @id @default(cuid())
  name                  String
  description           String?
  durationMin           Int
  priceCents            Int
  discountPercentage    Int?
  active                Boolean                 @default(true)
  imageUrl              String?
  carTypes              String[]
  attributeValues       Json?
  serviceTypeId         String?
  createdAt             DateTime                @default(now())
  updatedAt             DateTime                @default(now()) @updatedAt
  Booking               Booking[]
  PartnerServiceRequest PartnerServiceRequest[]
  SpotOrder             SpotOrder[]
  ServiceAreaPrice      ServiceAreaPrice[]
  ServiceType           ServiceType?            @relation(fields: [serviceTypeId], references: [id])
}

model ServiceAreaPrice {
  id                 String   @id @default(cuid())
  serviceId          String
  areaId             String
  priceCents         Int
  discountPercentage Int?
  active             Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @default(now())
  Area               Area     @relation(fields: [areaId], references: [id], onDelete: Cascade)
  Service            Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@unique([serviceId, areaId])
  @@index([areaId])
  @@index([serviceId])
}

model ServiceType {
  id                    String                  @id @default(cuid())
  name                  String                  @unique
  description           String?
  icon                  String?
  color                 String?
  active                Boolean                 @default(true)
  sortOrder             Int                     @default(0)
  attributes            Json?
  createdAt             DateTime                @default(now())
  updatedAt             DateTime                @default(now()) @updatedAt
  MonthlyPackage        MonthlyPackage[]
  PartnerServiceRequest PartnerServiceRequest[]
  Service               Service[]
}

model Session {
  id           String   @id
  sessionToken String   @unique
  userId       String
  expires      DateTime
  User         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Settings {
  id          String   @id
  key         String   @unique
  value       String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime
}

model SubscriptionDailyDriver {
  id                  String              @id
  subscriptionId      String
  date                String
  driverId            String
  taskStatus          TaskStatus          @default(ASSIGNED)
  taskStartedAt       DateTime?
  taskCompletedAt     DateTime?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime
  User                User                @relation(fields: [driverId], references: [id])
  PackageSubscription PackageSubscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@index([subscriptionId, date])
}

model SubscriptionRequest {
  id                                           String                    @id @default(cuid())
  userId                                       String
  packageId                                    String
  serviceTypeId                                String?
  serviceTypeName                              String?
  selectedAttributes                           String?
  status                                       SubscriptionRequestStatus @default(PENDING)
  scheduleDates                                String[]                  @default([])
  vehicleMake                                  String?
  vehicleModel                                 String?
  vehicleColor                                 String?
  vehicleType                                  String?
  vehiclePlate                                 String?
  locationLabel                                String?
  locationCoordinates                          String?
  paymentIntentId                              String?
  subscriptionId                               String?
  rejectionReason                              String?
  approvedAt                                   DateTime?
  rejectedAt                                   DateTime?
  completedAt                                  DateTime?
  processedAt                                  DateTime?
  processedById                                String?
  createdAt                                    DateTime                  @default(now())
  updatedAt                                    DateTime                  @default(now()) @updatedAt
  MonthlyPackage                               MonthlyPackage            @relation(fields: [packageId], references: [id])
  User_SubscriptionRequest_processedByIdToUser User?                     @relation("SubscriptionRequest_processedByIdToUser", fields: [processedById], references: [id])
  User_SubscriptionRequest_userIdToUser        User                      @relation("SubscriptionRequest_userIdToUser", fields: [userId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([userId, status])
}

model User {
  id                                                          String                    @id @default(cuid())
  name                                                        String?
  email                                                       String?                   @unique
  passwordHash                                                String?
  phoneNumber                                                 String?
  phoneVerified                                               Boolean                   @default(false)
  role                                                        UserRole                  @default(USER)
  image                                                       String?
  emailVerified                                               DateTime?
  emailVerificationToken                                      String?
  emailVerificationExpires                                    DateTime?
  passwordResetToken                                          String?
  passwordResetExpires                                        DateTime?
  partnerId                                                   String?
  loyaltyRedeemedPoints                                       Int                       @default(0)
  loyaltyCreditCents                                          Int                       @default(0)
  refreshToken                                                String?
  oneTimeCode                                                 String?
  oneTimeCodeExpiry                                           DateTime?
  pushSubscription                                            String?
  tokenVersion                                                Int                       @default(0)
  fcmToken                                                    String?
  createdAt                                                   DateTime                  @default(now())
  updatedAt                                                   DateTime                  @default(now())
  roleId                                                      String?
  currentLatitude                                             Float?
  currentLongitude                                            Float?
  locationUpdatedAt                                           DateTime?
  Account                                                     Account[]
  Booking_Booking_driverIdToUser                              Booking[]                 @relation("Booking_driverIdToUser")
  Booking_Booking_userIdToUser                                Booking[]                 @relation("Booking_userIdToUser")
  BusinessHours                                               BusinessHours[]
  ChatConversation_ChatConversation_customerIdToUser          ChatConversation[]        @relation("ChatConversation_customerIdToUser")
  ChatConversation_ChatConversation_driverIdToUser            ChatConversation[]        @relation("ChatConversation_driverIdToUser")
  ChatMessage                                                 ChatMessage[]
  Coupon                                                      Coupon[]
  CouponRedemption                                            CouponRedemption[]
  DriverDay                                                   DriverDay[]
  DriverBreak_DriverBreak_driverIdToUser                      DriverBreak[]              @relation("DriverBreak_driverIdToUser")
  DriverBreakApprovalRequest                                   DriverBreakApprovalRequest[]
  Feedback                                                    Feedback[]
  Notification                                                Notification[]
  PackageSubscription_PackageSubscription_driverIdToUser      PackageSubscription[]     @relation("PackageSubscription_driverIdToUser")
  PackageSubscription_PackageSubscription_userIdToUser        PackageSubscription[]     @relation("PackageSubscription_userIdToUser")
  Partner_Partner_userIdToUser                                Partner?                  @relation("Partner_userIdToUser")
  PartnerDriverRequest                                        PartnerDriverRequest[]
  PartnerPayout                                               PartnerPayout[]
  PartnerServiceRequest                                       PartnerServiceRequest[]
  PushSubscription                                            PushSubscription[]
  Session                                                     Session[]
  SubscriptionDailyDriver                                     SubscriptionDailyDriver[]
  SubscriptionRequest_SubscriptionRequest_processedByIdToUser SubscriptionRequest[]     @relation("SubscriptionRequest_processedByIdToUser")
  SubscriptionRequest_SubscriptionRequest_userIdToUser        SubscriptionRequest[]     @relation("SubscriptionRequest_userIdToUser")
  Partner_User_partnerIdToPartner                             Partner?                  @relation("User_partnerIdToPartner", fields: [partnerId], references: [id])
  Role                                                        Role?                     @relation(fields: [roleId], references: [id])
  UserLocation                                                UserLocation[]
  UserModulePermission                                        UserModulePermission[]
  UserPermission                                              UserPermission[]
  SavedPaymentMethod                                          SavedPaymentMethod[]
  fcm_tokens                                                  fcm_tokens[]
  User_SpotOrder_driverIdToUser                               SpotOrder[]               @relation("SpotOrder_driverIdToUser")
}

model UserLocation {
  id        String   @id @default(cuid())
  userId    String
  label     String
  address   String
  latitude  Float?
  longitude Float?
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now())
  User      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model UserModulePermission {
  id        String  @id
  userId    String
  moduleId  String
  enabled   Boolean @default(true)
  canView   Boolean @default(true)
  canCreate Boolean @default(false)
  canEdit   Boolean @default(false)
  canDelete Boolean @default(false)
  Module    Module  @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  User      User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, moduleId])
  @@index([moduleId])
  @@index([userId])
}

model UserPermission {
  id           String     @id
  userId       String
  permissionId String
  granted      Boolean
  Permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  User         User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, permissionId])
}

model VerificationToken {
  id         String   @id
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

model fcm_tokens {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  appType   AppType
  platform  Platform
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now())
  User      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, appType, platform])
  @@index([userId])
}

model invoice_sequences {
  id           String   @id @default(cuid())
  areaCode     String
  year         Int
  currentValue Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @default(now())

  @@unique([areaCode, year])
}

model live_tracking_events {
  id           String            @id
  bookingId    String
  driverId     String
  latitude     Float
  longitude    Float
  speed        Float?
  heading      Float?
  accuracy     Float?
  batteryLevel Float?
  eventType    TrackingEventType @default(LOCATION_UPDATE)
  createdAt    DateTime          @default(now())

  @@index([bookingId, createdAt])
  @@index([driverId, createdAt])
}

model notifications_v2 {
  id          String               @id
  userId      String
  appType     AppType
  title       String
  body        String
  category    NotificationCategory
  entityType  String?
  entityId    String?
  actionUrl   String?
  payload     Json?
  status      NotificationStatusV2 @default(PENDING)
  deliveredAt DateTime?
  readAt      DateTime?
  createdAt   DateTime             @default(now())
  updatedAt   DateTime

  @@index([createdAt])
  @@index([userId, appType, createdAt])
  @@index([userId, appType, status])
}

model permissions_v2 {
  id                  String                @id
  key                 String                @unique
  name                String
  description         String?
  appType             AppType
  createdAt           DateTime              @default(now())
  user_permissions_v2 user_permissions_v2[]

  @@index([appType])
}

model system_events {
  id            String          @id
  eventType     SystemEventType
  category      EventCategory
  severity      EventSeverity   @default(INFO)
  title         String
  description   String
  entityType    String?
  entityId      String?
  actorId       String?
  actorType     ActorType?
  actorName     String?
  targetUserIds String[]        @default([])
  targetRoles   UserRole[]      @default([])
  latitude      Float?
  longitude     Float?
  metadata      Json?
  processed     Boolean         @default(false)
  processedAt   DateTime?
  createdAt     DateTime        @default(now())

  @@index([actorId])
  @@index([category, createdAt])
  @@index([entityType, entityId])
  @@index([eventType, createdAt])
  @@index([processed, createdAt])
}

model user_permissions_v2 {
  id             String         @id
  userId         String
  permissionId   String
  createdAt      DateTime       @default(now())
  permissions_v2 permissions_v2 @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([userId, permissionId])
  @@index([userId])
}

